generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  reviews       Review[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Review {
  id               String       @id @default(cuid())
  userId           String
  prUrl            String
  prOwner          String
  prRepo           String
  prNumber         String
  prTitle          String?
  filesReviewed    Int
  securityScore    Float
  readabilityScore Float
  performanceScore Float
  overallScore     Float
  totalIssues      Int
  criticalCount    Int
  warningCount     Int
  infoCount        Int
  createdAt        DateTime     @default(now())
  commentPostCount Int          @default(0)
  fileResults      FileResult[]
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FileResult {
  id               String  @id @default(cuid())
  reviewId         String
  filename         String
  summary          String?
  issues           Json
  securityScore    Float?
  readabilityScore Float?
  performanceScore Float?
  skipped          Boolean @default(false)
  review           Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}
